# LittleJoys Persona Engine — Environment Configuration
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Environment
ENVIRONMENT=development  # development | staging | production

# LLM Configuration
# Local: set a real key below. Streamlit Cloud: ANTHROPIC_API_KEY in app Secrets (takes priority at runtime).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL_REASONING=claude-opus-4-6
LLM_MODEL_BULK=claude-sonnet-4-6
LLM_CACHE_ENABLED=true
LLM_MOCK_ENABLED=true
LLM_MAX_CONCURRENCY=5

# Population Generation
POPULATION_SEED=42
POPULATION_SIZE=300
DEEP_PERSONA_COUNT=30

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Streamlit
STREAMLIT_SERVER_PORT=8502
